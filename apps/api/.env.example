APP_NAME=ShelfDrive
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en

LOG_CHANNEL=stack
LOG_LEVEL=debug

# --- Database ---
# SQLite is the default for local dev. For production, switch DB_CONNECTION
# to mysql/pgsql and populate the matching credentials below.
DB_CONNECTION=sqlite
DB_DATABASE=database/database.sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_USERNAME=
# DB_PASSWORD=

# --- Session / Cache / Queue ---
SESSION_DRIVER=database
SESSION_LIFETIME=120
CACHE_STORE=database
QUEUE_CONNECTION=sync

# --- Mail (log driver is safe for local dev) ---
MAIL_MAILER=log
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# --- Sanctum ---
# Token lifetime used by AuthController (hours). 0 = no expiration.
SANCTUM_TOKEN_EXPIRATION_HOURS=8

# --- Rate limiting ---
# Max requests per minute for public auth endpoints (login, register,
# forgot/reset password). Keyed by authenticated user or IP.
AUTH_THROTTLE_PER_MINUTE=10

# --- Email verification ---
# How long the signed verification link stays valid (minutes).
VERIFICATION_LINK_TTL_MINUTES=60
# Domains that receive stateful auth cookies. Only needed when the web app
# uses SPA-cookie auth instead of the default bearer-token auth.
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:3000,127.0.0.1,127.0.0.1:8000

# --- CORS ---
# Comma-separated list of origins that may call the API from a browser.
# The web app origin(s) must be listed here.
CORS_ALLOWED_ORIGINS=http://localhost:3000
CORS_ALLOWED_ORIGIN_PATTERNS=
CORS_MAX_AGE=0
# Only set to true when using SPA-cookie auth mode.
CORS_SUPPORTS_CREDENTIALS=false

# --- Frontend ---
FRONTEND_URL=http://localhost:3000

# --- Google OAuth: app login client ---
# User-facing primary identity. Scopes are minimal: openid, email, profile.
GOOGLE_LOGIN_CLIENT_ID=
GOOGLE_LOGIN_CLIENT_SECRET=
GOOGLE_LOGIN_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback

# --- Google OAuth: drive-connect client ---
# Distinct client so revoking Drive access does not sign the user out.
# Scopes use least privilege: drive.readonly to scan + view, drive.file to
# manage only files the app uploads.
GOOGLE_DRIVE_CLIENT_ID=
GOOGLE_DRIVE_CLIENT_SECRET=
GOOGLE_DRIVE_REDIRECT_URI=http://localhost:8000/api/v1/drive/oauth/callback
GOOGLE_DRIVE_SCOPES="https://www.googleapis.com/auth/drive.readonly https://www.googleapis.com/auth/drive.file"
# Folder name auto-created in each connected Drive on first upload.
GOOGLE_DRIVE_DEFAULT_FOLDER_NAME=ShelfDrive

# --- Drive sync ---
# Cadence for incremental change polling and per-account scan concurrency.
DRIVE_SYNC_INTERVAL_MINUTES=15
DRIVE_SCAN_CONCURRENCY_PER_ACCOUNT=5
