# Public app branding
NEXT_PUBLIC_APP_NAME=ShelfDrive

# Absolute URL of the API, including the /api/v1 prefix.
# - Direct mode (default):  http://localhost:8000/api/v1
# - Same-origin proxy mode: /api/v1   (requests go through /app/api/[...path] route)
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1

# Authentication mode. One of: bearer (default) | cookie | mock | google
# - bearer: production-shaped auth via Sanctum tokens in localStorage.
# - cookie: Sanctum SPA-cookie mode. Requires SANCTUM_STATEFUL_DOMAINS + CORS_SUPPORTS_CREDENTIALS=true on the API.
# - mock:   frontend-only development. No API calls; login/register always "succeed" as a fixture user.
# - google: ShelfDrive primary-Google-account login. Mints a Sanctum bearer token via the API google_oauth flow.
NEXT_PUBLIC_AUTH_MODE=google

# Server-side proxy target (used only by app/api/[...path]/route.ts). This
# should be the API origin WITHOUT any path. Leave unset to reuse the origin
# from NEXT_PUBLIC_API_BASE_URL.
API_PROXY_TARGET=http://localhost:8000
