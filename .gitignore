# Laravel
apps/api/vendor/
# bootstrap/cache and storage/ directories are kept via nested .gitignore
# files so `composer install` / `artisan` have somewhere to write runtime
# artifacts. Their contents are ignored by those nested files.
apps/api/*.cache

# SQLite local DB
apps/api/database/*.sqlite
apps/api/database/*.sqlite-journal

# Build outputs
apps/*/dist/
public/build/

# OS
Thumbs.db
